{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "displayName", "createdAt"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User study progress",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "correctAnswers": {
          "type": "number"
        },
        "exercisesCompleted": {
          "type": "number"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "branch", "topic", "correctAnswers", "exercisesCompleted", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/progress/{progressId}": {
      "schema": { "$ref": "#/entities/Progress" },
      "description": "Study progress for each user"
    }
  }
}
